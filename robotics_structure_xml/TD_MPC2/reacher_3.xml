<mujoco model="reacher_3">
  <compiler angle="radian" inertiafromgeom="true"/>
  <default>
    <joint armature="1" damping="1" limited="true"/>
    <geom contype="0" friction="1 0.1 0.1" rgba="0.7 0.7 0 1"/>
  </default>
  <option gravity="0 0 -9.81" integrator="RK4" timestep="0.01"/>

  <worldbody>
    <geom conaffinity="0" contype="0" name="ground" pos="0 0 0" rgba="0.9 0.9 0.9 1" size="1 1 10" type="plane"/>
    <geom conaffinity="0" fromto="-.3 -.3 .01  .3 -.3 .01" name="sideS" rgba="0.9 0.4 0.6 1" size=".02" type="capsule"/>
    <geom conaffinity="0" fromto=" .3 -.3 .01  .3  .3 .01" name="sideE" rgba="0.9 0.4 0.6 1" size=".02" type="capsule"/>
    <geom conaffinity="0" fromto="-.3  .3 .01  .3  .3 .01" name="sideN" rgba="0.9 0.4 0.6 1" size=".02" type="capsule"/>
    <geom conaffinity="0" fromto="-.3 -.3 .01 -.3  .3 .01" name="sideW" rgba="0.9 0.4 0.6 1" size=".02" type="capsule"/>

    <!-- 3-link Arm 同上，略 -->
    <geom conaffinity="0" contype="0" fromto="0 0 0 0 0 0.02" name="root" rgba="0.9 0.4 0.6 1" size=".011" type="cylinder"/>
    <body name="body0" pos="0 0 .01">
      <geom  name="link0" type="capsule" size=".01" rgba="0.0 0.4 0.6 1" fromto="0 0 0 0.10 0 0"/>
      <joint name="joint0" type="hinge" axis="0 0 1" pos="0 0 0" limited="false"/>
      <body name="body1" pos="0.10 0 0">
        <geom  name="link1" type="capsule" size=".01" rgba="0.0 0.4 0.6 1" fromto="0 0 0 0.10 0 0"/>
        <joint name="joint1" type="hinge" axis="0 0 1" pos="0 0 0" range="-3.0 3.0"/>
        <body name="body2" pos="0.10 0 0">
          <geom  name="link2" type="capsule" size=".01" rgba="0.0 0.4 0.6 1" fromto="0 0 0 0.10 0 0"/>
          <joint name="joint2" type="hinge" axis="0 0 1" pos="0 0 0" range="-3.0 3.0"/>
          <body name="fingertip" pos="0.11 0 0">
            <geom name="fingertip" type="sphere" size=".01" rgba="0.0 0.8 0.6 1" contype="0" pos="0 0 0"/>
          </body>
        </body>
      </body>
    </body>

    <body name="target" pos=".1 -.1 .01">
      <joint name="target_x" type="slide" axis="1 0 0" range="-.27 .27" ref=".1"  armature="0" stiffness="0" damping="0" limited="true"/>
      <joint name="target_y" type="slide" axis="0 1 0" range="-.27 .27" ref="-.1" armature="0" stiffness="0" damping="0" limited="true"/>
      <geom  name="target"  type="sphere" size=".009" rgba="0.9 0.2 0.2 1" conaffinity="0" contype="0"/>
    </body>
  </worldbody>

  <actuator>
    <motor joint="joint0" gear="200" ctrllimited="true" ctrlrange="-1 1"/>
    <motor joint="joint1" gear="200" ctrllimited="true" ctrlrange="-1 1"/>
    <motor joint="joint2" gear="200" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
