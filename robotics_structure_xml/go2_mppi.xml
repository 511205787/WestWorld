      <geom friction="0.6" margin="0.001" condim="1"/>
      <joint axis="0 1 0" damping="2" armature="0.01" frictionloss="0.2"/>
      <general forcerange="-23.7 23.7" biastype="affine" gainprm="55 0 0 0 0 0 0 0 0 0" biasprm="0 -55 -3 0 0 0 0 0 0 0"/>
      <default class="abduction">
        <joint axis="1 0 0" damping="1" range="-1.0472 1.0472"/>
        <general ctrlrange="-1.0472 1.0472"/>
      </default>
      <default class="hip">
        <joint range="-1.5708 3.4907"/>
        <general ctrlrange="-1.5708 3.4907"/>
      </default>
      <default class="knee">
        <joint range="-2.7227 -0.83776"/>
        <general ctrlrange="-2.7227 -0.83776" forcerange="-45.43 45.43"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" material="dark"/>
      </default>
      <default class="collision">
        <geom group="3" type="capsule"/>
        <default class="foot">
          <geom type="sphere" size="0.022" pos="0 0 -0.213" priority="1" solimp="0.015 1 0.031" condim="6"
            friction="0.8 0.02 0.01"/>
        </default>
